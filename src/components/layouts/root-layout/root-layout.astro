---
import "@/styles/global.css"

import type { HTMLAttributes } from "astro/types"

import { Footer, Header } from "@/components/layouts"
import { Toaster } from "@/components/ui/toaster"
import initColorSchemeScript from "@/features/color-scheme/scripts/init-color-scheme?transform"
import { cn, getLanguageFromLocale, type PartiallyPartial } from "@/lib/utils"

import { SEO, type SEOProps } from "./seo"

// Astro can't parse complex types
// prettier-ignore
export type Props = PartiallyPartial<SEOProps, "titleSuffix" | "favicon" | "locale" | "image"> & HTMLAttributes<"body"> & {
  pagefindBody?: boolean
}

const {
  title,
  titleSuffix = "r4ai",
  description,
  favicon = "/favicon-96.png",
  image = new URL("/open-graph.png", Astro.url),
  locale = "ja_JP",
  pagefindBody = true,
  url,
  og,
  twitter,
  class: className,
} = Astro.props
---

<html
  lang={getLanguageFromLocale(locale)}
  data-color-scheme="light"
  class="h-full"
>
  <head prefix="og: https://ogp.me/ns#">
    <SEO
      {title}
      {titleSuffix}
      {description}
      {favicon}
      {image}
      {locale}
      {og}
      {twitter}
      {url}
    />
    <script is:inline set:html={initColorSchemeScript} data-cfasync="false" />
  </head>
  <body class="bg-background text-foreground flex min-h-full flex-col">
    <Header />
    <main
      class={cn("flex-1", className)}
      {...pagefindBody ? { "data-pagefind-body": true } : {}}
    >
      <slot />
    </main>
    <Footer />
    <Toaster client:only="solid-js" />
  </body>
</html>
