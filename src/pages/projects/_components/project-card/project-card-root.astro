---
import type { ImageMetadata } from "astro"
import { Picture } from "astro:assets"

import { cn } from "@/lib/utils"

import { ProjectCard, type ProjectCardProps } from "./project-card"
import {
  LARGE_PROJECT_CARD_IMAGE_SIZES,
  PROJECT_CARD_IMAGE_WIDTHS,
} from "./project-card-image"

type ImageProps = {
  src: ImageMetadata
  alt: string
  loading?: "eager" | "lazy"
  fetchpriority?: "high" | "low" | "auto"
  sizes?: string
  class?: string
}

export type Props = Omit<ProjectCardProps, "image" | "hasImage"> & {
  image?: ImageProps
}
const { image, ...props } = Astro.props
const projectCardProps = { ...(props as ProjectCardProps), hasImage: !!image }
const pictureProps = image
  ? {
      src: image.src,
      alt: image.alt,
      loading: image.loading,
      fetchpriority: image.fetchpriority,
      widths: [...PROJECT_CARD_IMAGE_WIDTHS],
      sizes: image.sizes ?? LARGE_PROJECT_CARD_IMAGE_SIZES,
      class: cn("size-full rounded-xl object-cover object-top", image.class),
    }
  : undefined
---

<ProjectCard {...projectCardProps as ProjectCardProps}>
  {image && <Picture {...pictureProps!} />}
</ProjectCard>
