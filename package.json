{
  "name": "r4ai-dev",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "type-check": "astro check",
    "lint": "eslint .",
    "lint:write": "eslint --fix .",
    "format": "prettier --ignore-path .gitignore --check './**/*.{js,cjs,mjs,ts,jsx,tsx,astro,json,html,md}'",
    "format:write": "prettier --ignore-path .gitignore --write './**/*.{js,cjs,mjs,ts,jsx,tsx,astro,json,html,md}'",
    "check": "pnpm run lint && pnpm run format",
    "check:write": "pnpm run lint:write && pnpm run format:write",
    "astro": "astro",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test:ci:unit": "node --test tests/remark-link-card.node-test.ts scripts/security/*.test.mjs",
    "test:vrt:unit": "node --test tests/storybook/*.node-test.ts",
    "test:vrt": "playwright test --config=playwright.vrt.config.ts",
    "test:vrt:update": "playwright test --config=playwright.vrt.config.ts --update-snapshots"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
